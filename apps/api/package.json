{
  "name": "@formsmithapp/api",
  "version": "0.0.0",
  "description": "Formsmith data-plane API (Hono) \u2014 mountable into the unified web build today, standalone-deployable (Node/Workers) tomorrow.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@formsmithapp/adapters": "workspace:*",
    "@formsmithapp/ai": "workspace:*",
    "@formsmithapp/blocks": "workspace:*",
    "@formsmithapp/db": "workspace:*",
    "@formsmithapp/engine": "workspace:*",
    "@formsmithapp/schemas": "workspace:*",
    "@hono/node-server": "^2.0.8",
    "@hono/zod-openapi": "^1.4.0",
    "@hono/zod-validator": "^0.8.0",
    "hono": "^4.12.27",
    "zod": "^4.4.3",
    "undici": "^7.16.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@formsmithapp/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "drizzle-orm": "^0.45.2",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.0"
  }
}
