# Formsmith environment — copy to .env (never commit .env)

# Postgres (compose.dev.yml default)
DATABASE_URL=postgres://formsmith:formsmith@localhost:5432/formsmith

# Better Auth — self-generated secret (e.g. `openssl rand -base64 32`), no external service
BETTER_AUTH_SECRET=change-me
BETTER_AUTH_URL=http://localhost:3000

# Optional social sign-in — buttons appear only when a provider's creds are set
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
