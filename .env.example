# Formsmith configuration — copy to `.env` (never commit .env).
# Self-hosting with compose.yml: only BETTER_AUTH_SECRET is required; every
# other setting is optional and its feature degrades gracefully when unset.
# Local development against compose.dev.yml: also set DATABASE_URL and
# BETTER_AUTH_URL below. Full reference: docs/self-hosting.md

# ── required ─────────────────────────────────────────────────────────────────
# Session/signing secret. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# ── instance ─────────────────────────────────────────────────────────────────
# The public URL respondents and owners use (behind your reverse proxy).
#FORMSMITH_URL=https://forms.example.com
# Host port the web container binds to.
#FORMSMITH_PORT=3000
# Password for the bundled postgres (change it on real deployments).
#POSTGRES_PASSWORD=
# Point at an external Postgres instead of the bundled one.
# (Local dev: postgres://formsmith:formsmith@localhost:5432/formsmith)
#DATABASE_URL=
# Local dev only — compose.yml derives this from FORMSMITH_URL instead.
#BETTER_AUTH_URL=http://localhost:3000

# ── AI (BYO key — unset means AI off, static fallbacks only) ─────────────────
#ANTHROPIC_API_KEY=
#FORMSMITH_AI_MODEL=
# ...or any OpenAI-compatible endpoint:
#OPENAI_COMPAT_BASE_URL=
#OPENAI_COMPAT_API_KEY=
#OPENAI_COMPAT_MODEL=
# ...or the Vercel AI Gateway: one key reaches many models. Set the model in
# FORMSMITH_AI_MODEL as a `creator/model` slug (e.g. google/gemini-2.0-flash,
# openai/gpt-4o-mini, anthropic/claude-haiku-4-5). Takes precedence when set.
#AI_GATEWAY_API_KEY=
# Optional hedged fallback model (fires after FORMSMITH_AI_HEDGE_MS if the
# primary hasn't answered; first success wins):
#FORMSMITH_AI_FALLBACK_PROVIDER=
#FORMSMITH_AI_FALLBACK_API_KEY=
#FORMSMITH_AI_FALLBACK_MODEL=
#FORMSMITH_AI_FALLBACK_BASE_URL=
#FORMSMITH_AI_HEDGE_MS=3000
#FORMSMITH_AI_TIMEOUT_MS=5000

# ── email notifications (BYO SMTP — unset means no emails) ───────────────────
#SMTP_URL=smtp://user:pass@smtp.example.com:587
#EMAIL_FROM=Formsmith <forms@example.com>

# ── social login (unset providers simply don't appear) ───────────────────────
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=
#GITHUB_CLIENT_ID=
#GITHUB_CLIENT_SECRET=

# ── self-host toggles ────────────────────────────────────────────────────────
# Hide the "Powered by Formsmith" badge on published forms.
#FORMSMITH_HIDE_BADGE=true
# Close registration once the instance owner has an account.
#FORMSMITH_DISABLE_SIGNUP=true
# Allow webhook deliveries to private/loopback addresses (e.g. n8n on the
# same box). Off by default — keep it off on internet-facing instances.
#WEBHOOK_ALLOW_PRIVATE=true
# Public submit rate limit per IP per form, per minute (default 60). Raise it
# if many respondents share one network (classrooms, offices behind NAT).
#FORMSMITH_SUBMIT_RATE=60
# Max entries in the in-memory cache (published snapshots, rate-limit
# windows). The default (500) is right for almost everyone.
#FORMSMITH_CACHE_MAX_ITEMS=500

# ── usage limits & AI credits (every one unset = unlimited) ──────────────────
# Cap AI spend and workspace resources. Leave any of these unset for no limit.
# AI credits per workspace, metered against AI follow-ups and generation.
#FORMSMITH_AI_CREDITS_DEFAULT=100
# Credits spent per AI form generation (default 5; each follow-up costs 1).
#FORMSMITH_AI_GENERATION_COST=5
# Max forms per workspace.
#FORMSMITH_LIMIT_FORMS=20
# Max responses per form, per calendar month.
#FORMSMITH_LIMIT_RESPONSES_MONTH=1000
# Max webhooks per form.
#FORMSMITH_LIMIT_WEBHOOKS=5
# Max API keys per workspace.
#FORMSMITH_LIMIT_API_KEYS=5

# ── signup hardening (all optional, off by default) ──────────────────────────
# Require a verified email before publishing forms or using AI. Building and
# previewing stay open. Needs SMTP configured (above); if it is not, verification
# is not enforced and a warning is logged, so you are never locked out.
#FORMSMITH_REQUIRE_EMAIL_VERIFICATION=true
# Cloudflare Turnstile on sign-up/sign-in. Both keys required, or it stays off.
#TURNSTILE_SECRET_KEY=
#TURNSTILE_SITE_KEY=

# ── respondent forms ─────────────────────────────────────────────────────────
# Serve public respondent forms on a separate host (e.g. a dedicated subdomain);
# unset = everything on one host. The app/auth host stays your FORMSMITH_URL.
#FORMSMITH_FORMS_HOST=forms.example.com
# Show a "Report abuse" link on public forms, pointing at this address.
#FORMSMITH_ABUSE_CONTACT=abuse@example.com
