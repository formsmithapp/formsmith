{
  "name": "@formsmithapp/ai",
  "version": "0.0.0",
  "description": "Formsmith AI loop — LSDE engagement scoring, guarded follow-up generation, hedged model providers, and AI form generation.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.8",
    "@ai-sdk/openai-compatible": "^3.0.5",
    "@formsmithapp/blocks": "workspace:*",
    "@formsmithapp/engine": "workspace:*",
    "@formsmithapp/schemas": "workspace:*",
    "ai": "^7.0.15",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@formsmithapp/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.0"
  }
}
