{
  "name": "@formsmithapp/ui",
  "version": "0.0.0",
  "description": "Formsmith design foundation — canonical design tokens, OKLCH theme derivation, and the self-hosted font-pair registry shared by the builder and runtime hosts.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./tailwind.css": "./dist/tailwind.css",
    "./fonts.css": "./dist/fonts/index.css",
    "./fonts/*": "./dist/fonts/*"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && node scripts/assets.mjs",
    "dev": "tsup --watch --onSuccess \"node scripts/assets.mjs\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@fontsource-variable/fraunces": "^5.2.0",
    "@fontsource-variable/instrument-sans": "^5.2.0",
    "@fontsource-variable/newsreader": "^5.2.0",
    "@fontsource-variable/schibsted-grotesk": "^5.2.0",
    "@formsmithapp/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.0"
  }
}
