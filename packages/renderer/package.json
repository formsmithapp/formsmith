{
  "name": "@formsmithapp/renderer",
  "version": "0.0.0",
  "description": "Formsmith respondent runtime \u2014 the thin view over the form engine (one-question stage, spring transitions, keyboard-first).",
  "license": "AGPL-3.0-only",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./fonts.css": "./dist/fonts.css",
    "./fonts/*": "./dist/fonts/*"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && node scripts/assets.mjs",
    "dev": "tsup --watch --onSuccess \"node scripts/assets.mjs\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@formsmithapp/engine": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@fontsource-variable/fraunces": "^5.2.0",
    "@fontsource-variable/instrument-sans": "^5.2.0",
    "@formsmithapp/tsconfig": "workspace:*",
    "@formsmithapp/ui": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/browser": "^3.2.0",
    "axe-core": "^4.10.0",
    "esbuild": "^0.28.1",
    "playwright": "^1.50.0",
    "preact": "^10.29.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.0"
  }
}
