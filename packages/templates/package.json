{
  "name": "@formsmithapp/templates",
  "version": "0.0.0",
  "description": "Formsmith starter templates — seed form documents (blocks, logic, themes) as data, with an instantiation helper.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@formsmithapp/engine": "workspace:*"
  },
  "devDependencies": {
    "@formsmithapp/blocks": "workspace:*",
    "@formsmithapp/tsconfig": "workspace:*",
    "@formsmithapp/ui": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.0"
  }
}
