{
  "name": "@formsmithapp/adapters",
  "version": "0.0.0",
  "description": "Formsmith infrastructure adapters — queue (pg-boss) and mail (SMTP) behind portable interfaces; more arrive with uploads/AI.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "nodemailer": "^9.0.3",
    "pg-boss": "^12.25.1"
  },
  "devDependencies": {
    "@formsmithapp/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.0"
  }
}
